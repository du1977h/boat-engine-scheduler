  "private": true,
  "scripts": {
    "setup:dev": "bash scripts/bootstrap-worktree.sh",
    "backup:create": "bash scripts/backup-required-files.sh",
    "dev": "next dev",
    "build": "next build",
    "build:prod": "next build && node scripts/prepare-runtime.mjs",
    "runtime:verify": "node scripts/verify-runtime.mjs",
